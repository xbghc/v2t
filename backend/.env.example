# AI 内容生成 (Anthropic 兼容)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# 语音转录 (OpenAI Whisper 兼容: Groq, OpenAI, 自托管 Qwen3-ASR 等)
# Groq 推荐 whisper-large-v3-turbo：免费层配额跟 v3 一样，速度快 14%、付费便宜 64%，WER 仅差 1.7%
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3-turbo

# 阿里云百炼 API (TTS 语音合成，可选)
DASHSCOPE_API_KEY=

# Xiazaitool API (视频链接解析)
XIAZAITOOL_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379
